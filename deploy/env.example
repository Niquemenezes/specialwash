# ══════════════════════════════════════════════════════════════
# .env.production - SW STUDIO en VPS (94.143.143.148)
# ══════════════════════════════════════════════════════════════
# Usar este template para crear .env en el servidor

# SEGURIDAD: Cambia estos valores ANTES de deploy
FLASK_ENV=production
ENABLE_ADMIN=0

# Claves secretas - GENÉRALAS NUEVAS Y ÚNICAS!
# Comando para generar en servidor: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_change_me_with_python3_secrets_256_chars_minimum_generated_key_here
JWT_SECRET_KEY=your_change_me_with_python3_secrets_256_chars_minimum_generated_key_here

# ──────────────────────────────────────────────────────────────
# BASE DE DATOS - SQLite (base de datos nueva y propia de SW Studio)
# ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////var/www/swstudio/data/swstudio.db
ENABLE_DB_BOOTSTRAP=0

# ──────────────────────────────────────────────────────────────
# FRONTEND - CORS (permite acceso desde tu dominio)
# ──────────────────────────────────────────────────────────────
FRONTEND_URLS=https://sw-studio.es,https://www.sw-studio.es

# ──────────────────────────────────────────────────────────────
# OPENAI - Opcional
# ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────────────────────
# WHATSAPP - Opcional
# ──────────────────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_RECIPIENT=34645811313

# ──────────────────────────────────────────────────────────────
# CLOUDINARY - Opcional
# ──────────────────────────────────────────────────────────────
CLOUDINARY_URL=

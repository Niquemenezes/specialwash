<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Producción con dominio y certificados válidos (Let's Encrypt) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">specialwash.studio</domain>
        <domain includeSubdomains="true">api.specialwash.studio</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Por defecto: solo certificados del sistema (rechaza autofirmados) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
